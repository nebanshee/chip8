}

// task4

int isPerfectSquare(int x) {
    int r = sqrt(x);
    return r * r == x;
}

void task4() {
    FILE *f = fopen("f.txt", "r");
    FILE *a = fopen("even.txt", "w");
    FILE *b = fopen("div3_not7.txt", "w");
    FILE *c = fopen("square.txt", "w");

    int x;
    while (fscanf(f, "%d", &x) != EOF) {
        if (x % 2 == 0)
            fprintf(a, "%d ", x);

        if (x % 3 == 0 && x % 7 != 0)
            fprintf(b, "%d ", x);

        if (x >= 0 && isPerfectSquare(x))
            fprintf(c, "%d ", x);
    }

    fclose(f);
    fclose(a);
    fclose(b);
    fclose(c);
    return 0;
}
