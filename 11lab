// task1

void copyFile(const char *from, const char *to) {
    FILE *f_from = fopen(from, "r");
    FILE *f_to = fopen(to, "w");
    char ch;

    while ((ch = fgetc(f_from)) != EOF) {
        fputc(ch, f_to);
    }

    fclose(f_from);
    fclose(f_to);
}

void task1()) {
    copyFile("f1.txt", "h.txt");
    copyFile("f2.txt", "f1.txt");
    copyFile("h.txt", "f2.txt");
    return 0;
}

// task2

void task2() {
    FILE *f = fopen("f.txt", "r");
    FILE *g = fopen("g.txt", "w");

    fseek(f, 0, SEEK_END);
    long size = ftell(f);

    for (long i = size - 1; i >= 0; i--) {
        fseek(f, i, SEEK_SET);
        fputc(fgetc(f), g);
    }

    fclose(f);
    fclose(g);
    return 0;
}

