// task 6

#define MAX 100
typedef struct {
    char brand[50];
    char number[20];
    char owner[50];
} Car;

void task6() {
    FILE *f = fopen("f.txt", "r");
    FILE *g = fopen("g.txt", "w");

    Car cars[MAX];
    int n = 0;

    while (fscanf(f, "%s %s %s", cars[n].brand, cars[n].number, cars[n].owner) != EOF) {
        n++;
    }

    char target[50] = "Toyota";

    fprintf(g, "Owners and numbers for brand %s:\n", target);
    for (int i = 0; i < n; i++) {
        if (strcmp(cars[i].brand, target) == 0) {
            fprintf(g, "%s %s\n", cars[i].owner, cars[i].number);
        }
    }

    fprintf(g, "\nCount by brand:\n");
    for (int i = 0; i < n; i++) {
        int count = 1;
        if (cars[i].brand[0] == '\0') continue;

        for (int j = i + 1; j < n; j++) {
            if (strcmp(cars[i].brand, cars[j].brand) == 0) {
                count++;
                cars[j].brand[0] = '\0';
            }
        }
        fprintf(g, "%s: %d\n", cars[i].brand, count);
    }

    fclose(f);
    fclose(g);
    return 0;
}
